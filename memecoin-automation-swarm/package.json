    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "hono": "^4.7.0",
    "ioredis": "^5.4.0",
    "level": "^10.0.0",
    "openai": "^4.77.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.0"
