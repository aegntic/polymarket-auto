# Memecoin Automation Swarm — Environment Configuration
# Copy to .env and fill in values

# === RPC Providers ===
# Solana (get from https://dev.helius.xyz)
HELIUS_API_KEY=
QUICKNODE_SOLANA_URL=
TRITON_ONE_URL=

# EVM (get from https://dashboard.alchemy.com)
ALCHEMY_BASE_API_KEY=
INFURA_BNB_PROJECT_ID=

# === LLM APIs ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Optional ===
# Local Ollama endpoint (fallback for ORACLE)
OLLAMA_BASE_URL=http://localhost:11434

# === Internal ===
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
GRAFANA_ADMIN_PASSWORD=admin

# === Chain Config ===
SOLANA_NETWORK=devnet
BASE_NETWORK=sepolia
BNB_NETWORK=testnet

# === Safety ===
MAX_CLONES_PER_DAY=50
MAX_LLM_BUDGET_DOLLARS=10
MAINNET_ENABLED=false
